---
import HeroBlock from '@/components/blocks/HeroBlock.astro'
import TextBlock from '@/components/blocks/TextBlock.astro'
import ImageBlock from '@/components/blocks/ImageBlock.astro'
import FooterBlock from '@/components/blocks/FooterBlock.astro'
import ContactBlock from '@/components/blocks/ContactBlock.astro'
import MenuBlock from '@/components/blocks/MenuBlock.astro'
import CourseBlock from '@/components/blocks/CourseBlock.astro'

interface Props {
  layout: Array<{ blockType: string; [key: string]: unknown }>
}

const { layout } = Astro.props

const components: Record<string, (_props: { data: unknown }) => any> = {
  hero: HeroBlock,
  text: TextBlock,
  image: ImageBlock,
  footer: FooterBlock,
  contact: ContactBlock,
  menu: MenuBlock,
  course: CourseBlock,
}
---

{layout.map((block) => {
  const Component = components[block.blockType]
  if (!Component) {
    if (import.meta.env.DEV) {
      console.warn(`[BlockRenderer] Unknown block type: "${block.blockType}"`)
    }
    return null
  }
  return <Component data={block} />
})}
