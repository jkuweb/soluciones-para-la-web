---
import type { CourseBlock } from '@/lib/types'
import { serializeLexical } from '@/lib/lexical'

interface Props {
  data: CourseBlock
}

const { data } = Astro.props
const descriptionHtml = data.description ? serializeLexical(data.description) : ''
---

<section class="course-block">
  <h3>{data.title}</h3>
  {descriptionHtml && <div class="description" set:html={descriptionHtml} />}
  {data.price && <span class="price">{data.price}€</span>}
  {data.duration && <p class="duration">Duración: {data.duration}</p>}
  {data.lessons && data.lessons.length > 0 && (
    <ul class="lessons">
      {data.lessons.map((lesson) => (
        <li>
          <strong>{lesson.title}</strong>
          {lesson.description && <p>{lesson.description}</p>}
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .course-block {
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1rem;
  }

  .course-block h3 {
    margin-bottom: 0.5rem;
  }

  .price {
    font-weight: 700;
    color: var(--primary-color);
    font-size: 1.25rem;
  }

  .duration {
    color: var(--secondary-color);
  }

  .lessons {
    list-style: none;
    margin-top: 1rem;
  }

  .lessons li {
    padding: 0.5rem 0;
    border-bottom: 1px solid #eee;
  }
</style>
