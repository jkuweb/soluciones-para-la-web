---
import { getMediaUrl } from '@/lib/payload'
import type { ImageBlock } from '@/lib/types'

interface Props {
  data: ImageBlock
}

const { data } = Astro.props
const imageUrl = data.image?.url ? getMediaUrl(data.image.url) : ''
---

<figure class="image-block">
  <img src={imageUrl} alt={data.caption || data.image?.alt || ''} loading="lazy" />
  {data.caption && <figcaption>{data.caption}</figcaption>}
</figure>

<style>
  .image-block {
    margin: 2rem auto;
    max-width: 1000px;
    text-align: center;
  }

  .image-block img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  figcaption {
    margin-top: 0.5rem;
    font-style: italic;
    color: #666;
  }
</style>
